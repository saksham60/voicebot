APP_NAME=hotel-digital-receptionist
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

HOTEL_NAME=Hotel Oman
HOTEL_TIMEZONE=Asia/Calcutta
HOTEL_PHONE_NUMBER=+15551234567
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

OPENAI_API_KEY=sk-your-openai-key
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VALIDATE_REQUESTS=false
TWILIO_TRANSFER_NUMBER=+15557654321

BOOKING_PROVIDER_NAME=manual-review

REQUEST_TIMEOUT_SECONDS=30
OPENAI_CONNECT_TIMEOUT_SECONDS=20
OPENAI_HEARTBEAT_SECONDS=20
